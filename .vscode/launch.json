{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Запуск теста test_masks.py",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/test_masks.py",
                "-v"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": true
        }
    ]
} 